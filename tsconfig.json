{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "allowJs": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"]
}