{
  "name": "bockscore-client",
  "version": "1.0.0",
  "description": "An alternative client to the bockscore app.",
  "scripts": {
    "start": "serve -l tcp://0.0.0.0:3000",
    "build": "esbuild src/main.ts --bundle --format=esm --loader:.css=css --loader:.html=text --outfile=dist/bundle.js",
    "dev": "esbuild src/main.ts --bundle --format=esm --loader:.css=css --loader:.html=text --outfile=dist/bundle.js --watch"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@types/bootstrap": "^5.2.11",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "esbuild": "^0.28.1",
    "serve": "^14.2.6"
  }
}
